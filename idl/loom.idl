    string drive_apply_share_expiry_json(LoomSession handle, string workspace,
                                         string drive_workspace_id, u64 now_ms);
    string drive_pin_retention_json(LoomSession handle, string workspace, string drive_workspace_id,
                                    string pin_id, string kind, string root,
                                    optional string target_entity_id, u64 added_at_ms,
                                    optional u64 expires_at_ms);
    string drive_unpin_retention_json(LoomSession handle, string workspace, string drive_workspace_id,
                                      string pin_id);
