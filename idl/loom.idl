                                  string source_message_ids_json, string prompt_text);
    string chat_agent_reply_json(LoomSession handle, string workspace, string chat_workspace_id,
                                 string channel_id, string invocation_id, string message_id);
    string chat_request_handoff_json(LoomSession handle, string workspace, string chat_workspace_id,
                                     string channel_id, string handoff_id,
