interface Tickets {
    string tickets_project_create_json(LoomSession handle, string workspace, string ticket_workspace_id,
                                       string project_id, string key_prefix, string name,
                                       optional string expected_root);
    string tickets_project_rekey_json(LoomSession handle, string workspace, string ticket_workspace_id,
                                      string project_id, string key_prefix,
                                      optional string expected_root);
    string tickets_project_settings_get_json(LoomSession handle, string workspace,
                                             string ticket_workspace_id, string project_id);
    string tickets_project_settings_set_json(LoomSession handle, string workspace,
                                             string ticket_workspace_id, string project_id,
                                             optional string default_projection,
                                             string enable_projections_json,
                                             string disable_projections_json,
                                             optional string actor_enforcement,
                                             optional string project_owner_principal,
                                             bool clear_project_owner_principal,
                                             optional string acceptance_authorities_json,
                                             optional string expected_root);
    string tickets_fields_json(LoomSession handle, string workspace, string ticket_workspace_id,
                               optional string project_id, optional string projection,
                               optional string operation);
    string tickets_field_put_json(LoomSession handle, string workspace, string ticket_workspace_id,
                                  string project_id, string field_id, string key, string name,
                                  optional string description, string field_type,
                                  optional string option_set, u32 max_length, bool has_max_length,
                                  bool required, bool searchable, bool orderable,
                                  string cardinality, string applicable_type_ids_json,
                                  optional string expected_root);
    string tickets_field_retire_json(LoomSession handle, string workspace,
                                     string ticket_workspace_id, string project_id,
                                     string field_id, optional string expected_root);
    // Ticket mutation JSON methods return `{ "resource": ..., "receipt": MutationReceipt }`.
    string tickets_create_json(LoomSession handle, string workspace, string ticket_workspace_id,
                               string project_id, string ticket_type,
                               optional string external_source, optional string external_id,
                               string fields_json, string policy_labels_json,
                               optional string expected_root);
    string tickets_update_json(LoomSession handle, string workspace, string ticket_workspace_id,
                               string ticket_id, optional string set_fields_json,
                               string delete_fields_json, optional string action,
                               optional string target_status, optional string observed_source_status,
                               optional string observed_workflow_version, optional string assignee,
                               optional string comment_id, optional string comment_type,
                               optional string comment_body, optional string expected_root,
                               optional string comments_json, optional string relation_sets_json,
                               optional string relation_removes_json);
    string tickets_delete_json(LoomSession handle, string workspace, string ticket_workspace_id,
                               string ticket_id, optional string expected_root);
    string tickets_comments_json(LoomSession handle, string workspace, string ticket_workspace_id,
                                 string ticket_id);
    string tickets_comment_add_json(LoomSession handle, string workspace, string ticket_workspace_id,
                                    string ticket_id, optional string comment_id,
                                    optional string comment_type, string body,
                                    optional string expected_root);
    string tickets_comment_update_json(LoomSession handle, string workspace,
                                       string ticket_workspace_id, string ticket_id,
                                       string comment_id, optional string comment_type,
                                       optional string body, optional string expected_root);
    string tickets_comment_delete_json(LoomSession handle, string workspace,
                                       string ticket_workspace_id, string ticket_id,
                                       string comment_id, optional string expected_root);
    string tickets_relation_set_json(LoomSession handle, string workspace, string ticket_workspace_id,
                                     string ticket_id, optional string relation_id, string kind,
                                     string target_id, optional string expected_root);
    string tickets_relation_remove_json(LoomSession handle, string workspace,
                                        string ticket_workspace_id, string ticket_id,
                                        string relation_id, optional string expected_root);
    string tickets_relation_list_json(LoomSession handle, string workspace,
                                      string ticket_workspace_id, string ticket_id);
    string tickets_get_json(LoomSession handle, string workspace, string ticket_workspace_id,
                            string ticket_id, optional string projection);
    string boards_create_json(LoomSession handle, string workspace, string ticket_workspace_id,
                              string request_json);
    string boards_get_json(LoomSession handle, string workspace, string ticket_workspace_id,
                           string board_id);
    string boards_list_json(LoomSession handle, string workspace, string ticket_workspace_id,
                            bool include_deleted);
    string boards_update_json(LoomSession handle, string workspace, string ticket_workspace_id,
                              string board_id, string request_json);
    string boards_delete_json(LoomSession handle, string workspace, string ticket_workspace_id,
                              string board_id, optional string expected_root);
    string boards_configure_columns_json(LoomSession handle, string workspace,
                                         string ticket_workspace_id, string board_id,
                                         string request_json);
    string boards_move_card_json(LoomSession handle, string workspace, string ticket_workspace_id,
                                 string board_id, string request_json);
    // Bounded, filtered, ordered, paginated ticket listing. `request` is an optional JSON object:
    // {projection, statuses[], assignees[], priorities[], ticket_types[], labels[], policy_labels[],
    // lane, board, ready, include_completed, limit, cursor}. Returns a JSON page {items[], total,
    // next_cursor}. Default 25, hard cap 100. Board-scoped lists use Board card order; Lane plus
    // Board intersects membership and uses Lane order; `next_cursor` is opaque.
    string tickets_list_json(LoomSession handle, string workspace, string ticket_workspace_id,
                             optional string request);
    string tickets_history_json(LoomSession handle, string workspace, string ticket_workspace_id,
                                optional string ticket_id);
}

