    string chat_add_reaction_json(LoomSession handle, string workspace, string chat_workspace_id,
                                  string channel_id, string message_id, string kind);
    string chat_remove_reaction_json(LoomSession handle, string workspace, string chat_workspace_id,
                                     string channel_id, string message_id, string kind);
    string chat_emoji_list_json(LoomSession handle, string workspace, string chat_workspace_id);
    string chat_emoji_register_json(LoomSession handle, string workspace, string chat_workspace_id,
                                    string kind);
    string chat_emoji_unregister_json(LoomSession handle, string workspace, string chat_workspace_id,
                                      string kind);
    string chat_messages_json(LoomSession handle, string workspace, string chat_workspace_id,
                              string channel_id);
    string chat_cursor_json(LoomSession handle, string workspace, string chat_workspace_id,
                            string channel_id);
    string chat_update_cursor_json(LoomSession handle, string workspace, string chat_workspace_id,
                                   string channel_id, u64 next_sequence);
    string chat_fetch_events_json(LoomSession handle, string workspace, string chat_workspace_id,
                                  string channel_id, u64 from_sequence, u64 max);
}

// ---- result rendering and diagnostics ----
// `result_to_json` renders a canonical-CBOR result buffer to debug JSON (for inspection, not the typed
// API). `result_to_bridge_json` renders the lossless React Native bridge projection, where big ints,
// decimals, uuids, inet, bytes, f32, non-finite f64, and points cross as tagged objects; it is not the
// normative wire form and not the general typed binding API. `last_error` returns this thread's most
// recent error.
interface Diagnostics {
    string result_to_json(bytes result);
    string result_to_bridge_json(bytes result);
    LastError last_error();
}

// ---- streaming iterators and asynchronous tasks ----
// `sql_query` (above) is projected by bindings as a stream; its source realization is a forward-only
// RowIter advanced by `iter_next` (which returns the next item's canonical-CBOR bytes, or none at
// end-of-stream) and released by `iter_free`. The async-first ops return a pollable Task: `sql_exec_async`
// (and the reader `*_async` forms below) start a pending task; `task_poll` drives it toward a terminal
// status and reports whether it is done (the first poll may block on the portable backend);
// `task_status` reports its TaskStatus or no value for an invalid handle; `task_result` takes the one
// owned result buffer, leaving the task TAKEN; `task_wait` polls to completion and takes the result in
// one call; `task_cancel` cancels a still-pending task; `task_free` releases the handle.
interface Tasks {
    optional bytes iter_next(RowIter iter);
    void iter_free(RowIter iter);
    Task sql_exec_async(SqlSession session, string sql);
    bool task_poll(Task task);
    optional TaskStatus task_status(Task task);
    bytes task_result(Task task);
    void task_cancel(Task task);
    void task_free(Task task);
    bytes task_wait(Task task);
}

// ---- result views ----
// A ResultView decodes a canonical-CBOR result buffer into an indexed, typed view so a binding need not
// parse CBOR or replicate the cell tag table. `result_open` decodes a full result (a list of statement
// items, or one reader item); `row_open` decodes a single streamed row from `iter_next` as item 0, row 0;
// `result_close` frees the view. A result is either a list of SQL statements (`result_is_statements`) or
// one reader result; `result_len` counts the items and `result_item_kind` gives each item's ResultKind.
// Sentinel-returning C accessors are optional here: invalid/null `result_is_statements` and
// out-of-range `result_item_kind` return no value.
// Select/Rows/Blame items expose `result_column_count`, `result_column_name`, `result_column_type`,
// `result_row_count`, `result_row_len`, and `result_cell`; a Blame row also carries the commit that last
// set it via `result_row_commit`. Count payloads (Insert/Delete/Update/DropTable) expose `result_count`.
// CommitLog/ShowVariable/Merge expose a string list via `result_string_count` and `result_string`, plus
// `result_variable_kind` and `result_merge_outcome`. Diff items expose `result_diff_count`,
// `result_diff_change`, and, over a DiffSide, `result_diff_len` and `result_diff_cell`. SelectMap rows
// expose `result_map_len` and `result_map_entry`. Cells decode as LoomValue.
interface ResultViews {
    ResultView result_open(bytes result);
    ResultView row_open(bytes row);
    void result_close(ResultView view);
    u64 result_len(ResultView view);
    optional bool result_is_statements(ResultView view);
    optional ResultKind result_item_kind(ResultView view, u64 item);
    u64 result_column_count(ResultView view, u64 item);
    string result_column_name(ResultView view, u64 item, u64 col);
    string result_column_type(ResultView view, u64 item, u64 col);
    u64 result_row_count(ResultView view, u64 item);
    u64 result_row_len(ResultView view, u64 item, u64 row);
    LoomValue result_cell(ResultView view, u64 item, u64 row, u64 col);
    string result_row_commit(ResultView view, u64 item, u64 row);
    u64 result_count(ResultView view, u64 item);
    u64 result_string_count(ResultView view, u64 item);
    string result_string(ResultView view, u64 item, u64 i);
    VariableKind result_variable_kind(ResultView view, u64 item);
    MergeOutcome result_merge_outcome(ResultView view, u64 item);
    u64 result_diff_count(ResultView view, u64 item);
    DiffChange result_diff_change(ResultView view, u64 item, u64 entry);
    u64 result_diff_len(ResultView view, u64 item, u64 entry, DiffSide side);
    LoomValue result_diff_cell(ResultView view, u64 item, u64 entry, DiffSide side, u64 col);
    u64 result_map_len(ResultView view, u64 item, u64 row);
    MapEntry result_map_entry(ResultView view, u64 item, u64 row, u64 idx);
}

// ---- direct table and history readers ----
// Table-model readers live on the concrete `Sql` interface and use the `sql_*` C ABI exports.
// Additional table facets can add the same reader family when they are promoted.

// ---- triggers ----
// Durable trigger bindings on the Program facet. A trigger binds a stimulus (a cron/timezone time rule
// or a change-watch selector) to a content-addressed program that fires under a budget and execution
// mode. `workspace` selects by UUID or name; a `trigger_put` by name ensures a Program-facet workspace.
// A binding and a fire record each cross as one Loom Canonical CBOR value: `trigger_put` takes a binding
// carrying its own `id`, `trigger_get`/`trigger_enable` return the binding, `trigger_list` returns the
// CBOR array of bindings in id order, and `trigger_history` returns the CBOR array of fire records
// ordered by fire sequence, starting at `from_seq` and bounded by `limit`. `trigger_get` on an unknown
// id is NOT_FOUND; `trigger_remove` returns whether a binding was present. Management requires Program
// facet WRITE for mutations and READ for reads, enforced by the same access-control path as other
// facets. Keeper due-evaluation and fire-record append are owned by the serving runtime and are not
// client-callable methods.
interface Triggers {
    void trigger_put(LoomSession handle, string workspace, bytes binding);
    bytes trigger_get(LoomSession handle, string workspace, Uuid id);
    bytes trigger_list(LoomSession handle, string workspace);
    bytes trigger_enable(LoomSession handle, string workspace, Uuid id, bool enabled);
    bool trigger_remove(LoomSession handle, string workspace, Uuid id);
    bytes trigger_history(LoomSession handle, string workspace, Uuid id, u64 from_seq, u64 limit);
}

// Byte-transfer interchange: the remote-capable import/export contract. The client owns all local
// filesystem paths; the server sees only opaque bytes, the target workspace, the payload kind, and
// integrity digests. Path-shaped import/export stays a local/admin surface (see FileSystem/Archive).
interface Transfer {
    TransferId transfer_import_open(LoomSession handle, string workspace, string kind, bytes opts);
    TransferAccept transfer_import_write(LoomSession handle, TransferId transfer, bytes chunk, u64 seq, optional Digest digest);
    bytes transfer_import_finish(LoomSession handle, TransferId transfer, bool commit, bool dry_run, Digest final_digest);
    void transfer_import_cancel(LoomSession handle, TransferId transfer);
    stream<bytes> transfer_export(LoomSession handle, string workspace, string kind, optional string revision, bytes opts);
}

// StoreAdmin: the server-owned store-administration contract (specs/0067 §13, task 640). Physical-store
// operations (maintenance stats, store policy, DEK rekey) run on the served store under global-admin
// authorization; the plaintext credential and the data-encryption key never cross the wire (rekey mints
// all key material server-side). `store init`/`store hash` stay local, and raw global `store get`/`put`
// are not exposed over remote (use workspace-scoped Cas or Transfer).
struct StoreStat {
    u64 object_count;
    u64 generation;
    u64 physical_page_count;
    u64 physical_bytes;
    u64 reusable_free_pages;
    u64 candidate_dead_pages;
    u64 last_validated_mark_epoch;
    u64 touched_segments;
    u64 candidate_segments;
    u64 segment_overflow;
}

struct StorePolicyResult {
    bool fips_required;
    optional u64 audit_seq;
}

struct StoreRekeyResult {
    u64 audit_seq;
    bool resealed;
    string suite;
    optional u64 bytes_before;
    optional u64 bytes_after;
}

interface StoreAdmin {
    bytes store_stat(LoomSession handle);
    bytes store_policy_get(LoomSession handle);
    bytes store_policy_set(LoomSession handle, bool fips_required);
    bytes store_rekey(LoomSession handle, bytes new_passphrase, bool reseal, optional string suite);
}
