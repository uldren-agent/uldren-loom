    string structures_add_node_json(LoomSession handle, string workspace,
                                    string page_workspace_id, string structure_id, string node_id,
                                    string kind, string label, optional string body_digest,
                                    optional string entity_ref, optional string expected_root);
    string structures_update_node_json(LoomSession handle, string workspace,
                                       string page_workspace_id, string structure_id,
                                       string node_id, string kind, string label,
                                       optional string body_digest, optional string entity_ref,
                                       optional string expected_root);
    string structures_bind_json(LoomSession handle, string workspace, string page_workspace_id,
                                string structure_id, string node_id, optional string entity_ref,
                                optional string expected_root);
    string structures_move_node_json(LoomSession handle, string workspace, string page_workspace_id,
                                     string structure_id, string node_id,
                                     optional string parent_node_id, optional string label,
                                     optional string expected_root);
    string structures_link_node_json(LoomSession handle, string workspace, string page_workspace_id,
                                     string structure_id, string edge_id, string src_node_id,
                                     string dst_node_id, string label, optional string target_ref,
                                     optional string expected_root);
    string structures_decompose_to_tickets_json(LoomSession handle, string workspace,
                                                string page_workspace_id, string structure_id,
                                                string items_json);
    string structures_get_json(LoomSession handle, string workspace, string page_workspace_id,
                               string structure_id);
    string structures_list_json(LoomSession handle, string workspace, string page_workspace_id);
}

// ---- time-series ----
// A versioned series of points keyed by an i64 timestamp, in time order. `workspace` selects by UUID or
// name; a `put` by name ensures a TimeSeries-facet workspace; a repeated timestamp replaces the point.
// `range` is half-open [from, to) and returns the canonical CBOR array of `[ts, value]` pairs; `latest`
// returns the most recent point as a single canonical `[ts, value]` CBOR pair (carrying both the
// timestamp and the value), or none. An absent timestamp or series reads as absent.
interface TimeSeries {
    void put(LoomSession handle, string workspace, string collection, i64 ts, bytes value);
    optional bytes get(LoomSession handle, string workspace, string collection, i64 ts);
    bytes range(LoomSession handle, string workspace, string collection, i64 from, i64 to);
    optional bytes latest(LoomSession handle, string workspace, string collection);
    // The collection (series-set) names present in the workspace, canonical CBOR array of strings.
    bytes list_collections(LoomSession handle, string workspace);
}

// ---- metrics ----
// Native metric descriptors and observations use Loom-owned canonical CBOR records. `workspace`
// selects by UUID or name; writes by name ensure a Metrics-facet workspace. `query` is half-open
// [from_timestamp_ms, to_timestamp_ms), bounded by scanned series, returned groups, samples, and
// output bytes, and returns canonical CBOR `[observations, partial, stale]`, where `observations` is
// an array of canonical observation record bytes.
interface Metrics {
    void put_descriptor(LoomSession handle, string workspace, bytes descriptor);
    optional bytes get_descriptor(LoomSession handle, string workspace, string name);
    void put_observation(LoomSession handle, string workspace, string descriptor_name,
                         bytes observation);
    bytes query(LoomSession handle, string workspace, string descriptor_name,
                u64 from_timestamp_ms, u64 to_timestamp_ms,
                u32 max_series, u32 max_groups, u32 max_samples,
                u64 max_output_bytes, u64 now_timestamp_ms);
}

// ---- logs ----
// Native log records use Loom-owned canonical CBOR records. `workspace` selects by UUID or name;
// writes by name ensure a Logs-facet workspace. `query` is half-open
// [from_time_unix_nano, to_time_unix_nano), bounded by returned records and output bytes, and returns
// canonical CBOR `[records, partial]`, where `records` is an array of canonical log record bytes.
interface Logs {
    string put_record(LoomSession handle, string workspace, bytes record);
    optional bytes get_record(LoomSession handle, string workspace, string record_id);
    bytes query(LoomSession handle, string workspace, u64 from_time_unix_nano,
                u64 to_time_unix_nano, u32 max_records, u64 max_output_bytes);
}

// ---- traces ----
// Native span records use Loom-owned canonical CBOR records. `workspace` selects by UUID or name;
// writes by name ensure a Traces-facet workspace. Trace listing and `query` return canonical CBOR
// `[spans, partial]`, where `spans` is an array of canonical span record bytes.
interface Traces {
    void put_span(LoomSession handle, string workspace, bytes span);
    optional bytes get_span(LoomSession handle, string workspace, string trace_id, string span_id);
    bytes trace_spans(LoomSession handle, string workspace, string trace_id, u32 max_spans,
                      u64 max_output_bytes);
    bytes query(LoomSession handle, string workspace, u64 from_start_time_ns,
                u64 to_start_time_ns, u32 max_spans, u64 max_output_bytes);
}

// ---- ledger ----
// A versioned, append-only, tamper-evident log: each entry is hash-chained to the previous under the
// store's identity profile. `workspace` selects by UUID or name; an `append` by name ensures a
// Ledger-facet workspace and returns the new zero-based sequence. `head` is the chain head digest the
// caller attests to (none for an empty ledger); `verify` recomputes the chain and fails with
// INTEGRITY_FAILURE on any altered payload or broken link. The chain is fast-forward-only; divergence
// is reconciled by replay, never a silent interleave.
interface Ledger {
    u64 append(LoomSession handle, string workspace, string collection, bytes payload);
    optional bytes get(LoomSession handle, string workspace, string collection, u64 seq);
    optional Digest head(LoomSession handle, string workspace, string collection);
    u64 len(LoomSession handle, string workspace, string collection);
    void verify(LoomSession handle, string workspace, string collection);
    // The collection (log) names present in the workspace, canonical CBOR array of strings.
    bytes list_collections(LoomSession handle, string workspace);
}

// ---- append-log queue ----
// `workspace` selects by UUID or name; an `append` by name ensures a Queue-facet workspace. `append`
// returns the assigned zero-based sequence. `range` is half-open [lo, hi) and ordered by sequence. An
// absent `get` returns no value.
interface Queue {
    u64 append(LoomSession handle, string workspace, string stream, bytes entry);
    optional bytes get(LoomSession handle, string workspace, string stream, u64 seq);
    list<bytes> range(LoomSession handle, string workspace, string stream, u64 lo, u64 hi);
    u64 len(LoomSession handle, string workspace, string stream);
    // The stream (collection) names present in the workspace, canonical CBOR array of strings.
    bytes list_streams(LoomSession handle, string workspace);
}

// ---- queue consumer offsets ----
// Per-consumer progress for a queue stream. Offsets are operational metadata in the local store: they
// are not part of workspace commits, stream roots, clone, push, bundle, or ordinary sync. A missing
// offset reads as next_seq 0. `consumer_read` does not advance; `consumer_advance` is monotonic (rejects
// backward) while `consumer_reset` may move backward. `consumer_id` is non-empty and free of `/`, NUL,
// and control characters.
interface QueueConsumers {
    u64 consumer_position(LoomSession handle, string workspace, string stream, string consumer_id);
    list<bytes> consumer_read(LoomSession handle, string workspace, string stream, string consumer_id,
                              u32 max);
    void consumer_advance(LoomSession handle, string workspace, string stream, string consumer_id,
                          u64 next_seq);
    void consumer_reset(LoomSession handle, string workspace, string stream, string consumer_id,
                        u64 next_seq);
}

// ---- sql sessions and transaction batches ----
// A session opens over a `.loom` path, a workspace name, and a database name; the workspace SQL facet is
// created if absent. `sql_exec` runs one or more `;`-separated statements and returns the result
// payloads as Loom Canonical CBOR; `sql_query` streams a SELECT's rows, each a canonical-CBOR cell
// array. `sql_commit` records a commit and returns its content address. A batch holds the store open so
// a SQL transaction (BEGIN/COMMIT/ROLLBACK) can span `sql_batch_exec` calls; `sql_batch_commit` makes
// accumulated changes durable with one atomic save, and `sql_batch_commit_vcs` also records a
// version-control commit and returns its address. `sql_batch_abort` discards un-persisted changes, and
// closing without a commit discards them too. Encrypted stores open with a passphrase or a 32-byte kek.
interface Sql {
    SqlSession sql_open(string loom_path, string workspace, string db);
    SqlSession sql_open_keyed(string loom_path, string workspace, string db, bytes passphrase);
    SqlSession sql_open_with_kek(string loom_path, string workspace, string db, bytes kek);
    SqlSession sql_open_authenticated(string loom_path, string workspace, string db,
                                      Uuid auth_principal, bytes auth_passphrase);
    SqlSession sql_open_keyed_authenticated(string loom_path, string workspace, string db,
                                            bytes passphrase, Uuid auth_principal,
                                            bytes auth_passphrase);
    SqlSession sql_open_with_kek_authenticated(string loom_path, string workspace, string db,
                                               bytes kek, Uuid auth_principal,
                                               bytes auth_passphrase);
    void sql_authenticate_passphrase(SqlSession session, Uuid principal, bytes passphrase);
    bytes sql_exec(SqlSession session, string sql);
    stream<bytes> sql_query(SqlSession session, string sql);
    Digest sql_commit(SqlSession session, string message, string author, u64 timestamp_ms);
    void sql_close(SqlSession session);

    SqlBatch sql_batch_begin(string loom_path, string workspace, string db);
    SqlBatch sql_batch_begin_keyed(string loom_path, string workspace, string db, bytes passphrase);
    SqlBatch sql_batch_begin_with_kek(string loom_path, string workspace, string db, bytes kek);
    SqlBatch sql_batch_begin_authenticated(string loom_path, string workspace, string db,
                                           Uuid auth_principal, bytes auth_passphrase);
    SqlBatch sql_batch_begin_keyed_authenticated(string loom_path, string workspace, string db,
                                                 bytes passphrase, Uuid auth_principal,
                                                 bytes auth_passphrase);
    SqlBatch sql_batch_begin_with_kek_authenticated(string loom_path, string workspace, string db,
                                                    bytes kek, Uuid auth_principal,
                                                    bytes auth_passphrase);
    bytes sql_batch_exec(SqlBatch batch, string sql);
    void sql_batch_commit(SqlBatch batch);
    Digest sql_batch_commit_vcs(SqlBatch batch, string message, string author);
    void sql_batch_abort(SqlBatch batch);
    void sql_batch_close(SqlBatch batch);

    // Handle-based direct/version-aware readers over the SQL facet's staged tables (bound to the sql
    // facet; decode with a ResultView). `sql_read_table` reads a staged table as columns and rows;
    // `sql_index_scan` returns the rows of secondary `index` matching `prefix` (a canonical-CBOR cell
    // array; an empty prefix is the canonical CBOR of an empty array); `sql_blame` returns each current
    // row of `table` on `branch` with the commit that last set it; `sql_diff` returns the row-level diff
    // of `table` between two commits; `sql_table_diff` returns schema-aware table records. The `_at`
    // readers read from a commit without changing the working tree. The current reader set has async
    // forms returning a Task.
    bytes sql_read_table(LoomSession handle, string workspace, string table);
    bytes sql_read_table_at(LoomSession handle, string workspace, string table, string commit);
    bytes sql_index_scan(LoomSession handle, string workspace, string table, string index, bytes prefix);
    bytes sql_index_scan_at(LoomSession handle, string workspace, string table, string index,
                            bytes prefix, string commit);
    bytes sql_blame(LoomSession handle, string workspace, string branch, string table);
    bytes sql_diff(LoomSession handle, string workspace, string table, string from_commit, string to_commit);
    bytes sql_table_diff(LoomSession handle, string workspace, string table, string from_commit,
                         string to_commit);
    Task sql_read_table_async(LoomSession handle, string workspace, string table);
    Task sql_index_scan_async(LoomSession handle, string workspace, string table, string index, bytes prefix);
    Task sql_blame_async(LoomSession handle, string workspace, string branch, string table);
    Task sql_diff_async(LoomSession handle, string workspace, string table, string from_commit,
                        string to_commit);
    // The database (collection) names present in the workspace, canonical CBOR array of strings.
    bytes sql_list_databases(LoomSession handle, string workspace);
    // Run a read-only query against database `db` and return the FULL result payload (the same canonical
    // CBOR `sql_exec` produces: an array of per-statement payloads carrying column labels and rows). Unlike
    // `sql_query` (which streams only the first SELECT's rows and drops the statement/label structure) this
    // returns the complete `exec_cbor` shape, and unlike `sql_exec` it never persists: a statement that
    // dirties the store is rejected, so the read-only contract is preserved. This backs the MCP
    // `sql_query` tool over remote at full parity.
    bytes sql_query_result(LoomSession handle, string workspace, string db, string sql);
}

